`timescale 1ns/1ps
module tb_RingCounter();
    logic clk, reset;
    logic [5:0] T;

    RingCounter uut (.*);

    always #5 clk = ~clk;

    initial begin
        clk = 0; reset = 1; #15;
        reset = 0;
        #100; // Watch T0 to T5 pulse in sequence
        $display("Ring Counter Test Complete");
        $stop;
    end
endmodule