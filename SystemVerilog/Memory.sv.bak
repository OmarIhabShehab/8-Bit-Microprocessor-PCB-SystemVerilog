// Memory.sv - ?????? ??? ?????
`timescale 1ns/1ps

module Memory #(
    parameter ADDR_WIDTH = 8,
    parameter DATA_WIDTH = 8
)(
    input  logic                   clk,
    input  logic                   WE,
    input  logic [ADDR_WIDTH-1:0]  addr,
    input  logic [DATA_WIDTH-1:0]  wd,
    output logic [DATA_WIDTH-1:0]  rd
);

    logic [DATA_WIDTH-1:0] RAM [0:(2**ADDR_WIDTH)-1];

    // Synchronous Write only
    always_ff @(posedge clk) begin
        if (WE)
            RAM[addr] <= wd;
    end

    // Asynchronous Read (instantaneous)
    assign rd = RAM[addr];

    initial begin
        RAM[0] = 8'h09;  // LDA 9
        RAM[1] = 8'h1A;  // ADD A
        RAM[2] = 8'h3B;  // STA B
        RAM[3] = 8'h40;  // OUT
        RAM[4] = 8'hF0;  // HALT

        RAM[8'h09] = 8'd5;
        RAM[8'h0A] = 8'd3;
        RAM[8'h0B] = 8'd0;
    end

endmodule